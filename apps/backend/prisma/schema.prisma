generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Service: monitored service definitions
// =====================================================
model Service {
  id               String      @id @default(cuid())
  name             String
  type             ServiceType
  target           String // HTTP URL, TCP host:port, etc.
  intervalSeconds  Int         @default(60)
  timeoutMs        Int         @default(5000)
  failureThreshold Int         @default(3)
  enabled          Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  checks    Check[]
  incidents Incident[]
  state     ServiceState?

  @@index([enabled])
}

// =====================================================
// Check: historical check results
// =====================================================
model Check {
  id         String      @id @default(cuid())
  serviceId  String
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status     CheckStatus
  latencyMs  Int?
  statusCode Int?
  error      String?
  timestamp  DateTime    @default(now())

  @@index([serviceId, timestamp(sort: Desc)])
}

// =====================================================
// Incident: a downtime window for a service
// =====================================================
model Incident {
  id            String    @id @default(cuid())
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  resolvedAt    DateTime?
  reason        String?
  rootCause     String?
  notifiedStart Boolean   @default(false)
  notifiedEnd   Boolean   @default(false)

  @@index([serviceId, resolvedAt])
}

// =====================================================
// Enums
// =====================================================
enum ServiceType {
  HTTP
  TCP
  PING
  DOCKER
}

enum CheckStatus {
  UP
  DOWN
  TIMEOUT
}

// =====================================================
// Current service state projection (latest status only, non-historical)
// =====================================================
model ServiceState {
  id            String      @id @default(cuid())
  serviceId     String      @unique
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  latestCheckId String?
  status        CheckStatus
  latencyMs     Int?
  statusCode    Int?
  error         String?
  updatedAt     DateTime    @updatedAt
}

// =====================================================
// UserContact: alert delivery endpoints
// =====================================================
model UserContact {
  id        String      @id @default(cuid())
  label     String // e.g. "Personal iPhone", "Primary email"
  type      ContactType
  value     String // EMAIL address or DISCORD webhook URL
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type, enabled])
}

enum ContactType {
  EMAIL
  DISCORD
}
